{
  "name": "pnake",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "PDF DevTools — a browser-only PDF structure inspector",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "BUILD_FOR_PAGES=1 tsc -b && BUILD_FOR_PAGES=1 vite build --outDir docs --emptyOutDir=false",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "format": "oxfmt --write src tests",
    "format:check": "oxfmt --check src tests",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "e2e": "playwright test --grep-invert 'README screenshots'",
    "e2e:install": "playwright install chromium",
    "capture:screenshots": "playwright test --grep 'README screenshots' --reporter=list && bash scripts/annotate.sh"
  },
  "dependencies": {
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.7.7",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/eslint-plugin": "^1.6.17",
    "@vitest/ui": "^4.1.6",
    "eslint": "^10.3.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.49.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  },
  "packageManager": "pnpm@9.15.4"
}
